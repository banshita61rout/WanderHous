<% layout("/layouts/boilerplate")%>
<!-- <h3>All Listings</h3> -->
<style>
  #filters {
    display: flex;
    flex-wrap: wrap;

  }

  .filter {
    text-align: center;
    margin-right: 1.3rem;
    margin-top: 2rem;
    opacity: 0.8;
    color: black;
    font-size: 0.8rem;
    text-decoration: none;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .filter i {
    display: block;
    margin-bottom: 0.5rem;
    color: rgb(69, 30, 69);
  }

  .filter a {
    color: #000000;
    text-decoration: none;
    font-weight: 400;
    font-size: 0.6rem;
  }

  .tax-info{
    display:none;

  }

  .tax-toggle{
    border:1px solid black;
    border-radius:1rem;
    height:2.8rem;
    padding:1rem;
    margin-top:0.9rem;
    margin-left:5rem;
    display:flex;
    align-items:center;

  }




</style>


<div id="filters">
  <div class="filter">
    <i class="fa-solid fa-house-chimney fa-xl"></i>
    <a href="/listings">Explore</a>
  </div>

  <div class="filter">
    <i class="fa-solid fa-fire fa-xl"></i>
    <p>Trending</p>
  </div>


  <div class="filter">
    <i class="fa-solid fa-bed fa-xl"></i>
    <p>Rooms</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-city fa-xl"></i>
    <p>Iconic cities</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-person-swimming fa-xl"></i>
    <p>Beach</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-mountain fa-xl"></i>
    <p>Amazing views</p>
  </div>

  
  <div class="filter">
    <i class="fa-solid fa-tent fa-xl"></i>
    <p>Camping</p>
  </div>

 

  <div class="filter">
    <i class="fa-solid fa-water-ladder fa-xl"></i>
    <p>Amazing pool</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-snowflake fa-xl"></i>
    <p>Arctic</p>
  </div>


  <div class="filter">
    <i class="fa-solid fa-tree fa-xl"></i>
    <p>Tropical</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-person-hiking fa-xl"></i>
    <p>Hiking</p>
  </div>



  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="flexswitchCheckDefault">Display total after taxes</label>
    </div>
  </div>



</div>


<div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-3 mt-3">
  <%  for(let listing of alllistings){  %>
  <a href="/listings/<%=listing._id%>" class="listing-link">
    <div class="card col listing-card">
      <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem" />
      <div class="card-img-overlay"></div>
      <div class="card-body">
        <p class="card-text">
          <b> <%= listing.title%> </b><br>
          &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> /Night
          <i class="tax-info">&nbsp; &nbsp;+12% GST</i>

        </p>
      </div>
    </div>
  </a>

  <% } %>
</div>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click",()=>{
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo){
      if(info.style.display!="inline"){
        info.style.display="inline";
      }
      else{
        info.style.display="none";
      }
    }
});
</script>